{
  "apps": [
    {
      "name": "Mako API Production",
      "script": "dist/main.js",
      "cwd": ".",
      "node_args": ["--max_old_space_size=8192"],
      "instances": 2,
      "exec_mode": "cluster",
      "watch": false,
      "error_file": "logs/mako-api-error.log",
      "out_file": "logs/mako-api-output.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss.SSS",
      "merge_logs": true,
      "autorestart": true,
      "max_memory_restart": "8G",
      "min_uptime": "10s",
      "max_restarts": 10,
      "restart_delay": 4000,
      "kill_timeout": 10000,
      "listen_timeout": 30000,
      "time": true,
      "env": {
        "NODE_ENV": "development",
        "PORT": 4000,
        "SERVE_CLIENT": "true"
      },
      "env_production": {
        "NODE_ENV": "production",
        "PORT": 4005,
        "SERVE_CLIENT": "true",
        "CORS_DISABLED": "true",
        "FRONTEND_URL": "https://mako.tekreminnovations.com",
        "API_PUBLIC_URL": "https://mako.tekreminnovations.com"
      }
    }
  ]
}
