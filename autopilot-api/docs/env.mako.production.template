# Mako production — autopilot-api (.env on server)
# Copy to autopilot-api/.env and fill secrets marked CHANGE_ME
# Matches config/production.yml (port 5000, DB autopilot_prod)

NODE_ENV=production
PORT=5000
APP_NAME=Tekrem Innovation Solutions - Mako

# Database (config/production.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=mako
DB_PASSWORD=CHANGE_ME
DB_DATABASE=autopilot_prod
DB_SYNCHRONIZE=false
DB_SSL=false

# Auth — use strong random values in production (not dev defaults)
JWT_SECRET=CHANGE_ME_LONG_RANDOM
SESSION_SECRET=CHANGE_ME_LONG_RANDOM

# URLs — frontend on mako.*, API on makoapi.*
FRONTEND_URL=https://mako.tekreminnovations.com
API_BASE_URL=https://makoapi.tekreminnovations.com
API_PUBLIC_URL=https://makoapi.tekreminnovations.com
CORS_ORIGIN=http://mako.tekreminnovations.com,https://mako.tekreminnovations.com
SUPPORT_EMAIL=tekremsolutions@gmail.com
PRIVACY_POLICY_URL=https://mako.tekreminnovations.com/privacy
TERMS_OF_SERVICE_URL=https://mako.tekreminnovations.com/terms

# OAuth callbacks (API host)
GOOGLE_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/auth/google/redirect
FACEBOOK_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/auth/facebook/redirect
LINKEDIN_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/auth/linkedin/redirect
INSTAGRAM_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/auth/instagram/redirect
LINKEDIN_SOCIAL_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/social-accounts/oauth/linkedin/callback
FACEBOOK_SOCIAL_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/social-accounts/oauth/facebook/callback
GOOGLE_SOCIAL_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/social-accounts/oauth/google/callback
YOUTUBE_SOCIAL_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/social-accounts/oauth/youtube/callback
INSTAGRAM_SOCIAL_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/social-accounts/oauth/instagram/callback
TIKTOK_SOCIAL_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/social-accounts/oauth/tiktok/callback
WHATSAPP_SOCIAL_CALLBACK_URL=https://makoapi.tekreminnovations.com/api/v1/social-accounts/oauth/whatsapp/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
META_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_RANDOM

# AI
MISTRAL_API_KEY=CHANGE_ME

# Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media

# Redis / queues + OAuth session store (required for PM2 cluster Google/Facebook login)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# SESSION_STORE=memory  # only if PM2 instances:1
QUEUES_ENABLED=true

# Crons
AUTO_PUBLISH_CRON_ENABLED=true
DAILY_WORKFLOW_CRON_ENABLED=true
COMMENT_SYNC_CRON_ENABLED=true
NOTIFICATION_CRON_ENABLED=true

# Payments
PAYMENTS_DEV_AUTO_COMPLETE=false

# Mail (config/production.yml)
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@mako.tekreminnovations.com

# Invoice / company
COMPANY_LEGAL_NAME=Tekrem Innovations
COMPANY_WEBSITE=https://www.tekreminnovations.com
SUPPORT_EMAIL=tekremsolutions@gmail.com

# Production seed (npm run seed:prod) — run once after migrations + first owner signup
# MAKO_WIDGET_API_KEY must match VITE_WIDGET_API_KEY in autopilot-client
SEED_MAKO_OWNER_EMAIL=tekremsolutions@gmail.com
