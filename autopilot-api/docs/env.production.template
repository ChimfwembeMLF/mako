# Production environment template — autopilot-api
# Copy to .env on your server (never commit real secrets)

NODE_ENV=production
PORT=4000
APP_NAME=Tekrem Innvation Solutions Autopilot

# Database
DB_HOST=your-db-host
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME
DB_DATABASE=autopilot_prod
DB_SYNCHRONIZE=false

# Auth
JWT_SECRET=CHANGE_ME_LONG_RANDOM
SESSION_SECRET=CHANGE_ME_LONG_RANDOM

# URLs
FRONTEND_URL=https://app.yourdomain.com
API_BASE_URL=https://api.yourdomain.com
API_PUBLIC_URL=https://api.yourdomain.com
CORS_ORIGIN=https://app.yourdomain.com

# OAuth — update ALL callback URLs to production
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/google/redirect
FACEBOOK_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/facebook/redirect
LINKEDIN_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/linkedin/redirect
INSTAGRAM_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/instagram/redirect
LINKEDIN_SOCIAL_CALLBACK_URL=https://api.yourdomain.com/api/v1/social-accounts/oauth/linkedin/callback
FACEBOOK_SOCIAL_CALLBACK_URL=https://api.yourdomain.com/api/v1/social-accounts/oauth/facebook/callback
GOOGLE_SOCIAL_CALLBACK_URL=https://api.yourdomain.com/api/v1/social-accounts/oauth/google/callback
INSTAGRAM_SOCIAL_CALLBACK_URL=https://api.yourdomain.com/api/v1/social-accounts/oauth/instagram/callback

# Meta webhooks (App Dashboard — subscribe to whatsapp_business_account messages)
META_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_RANDOM

# --- WhatsApp: platform mode (recommended for SaaS — YOU configure Meta once, clients click Enable) ---
# Get these from Meta Developer Console → WhatsApp → API Setup (test) or System User token (production)
WHATSAPP_PLATFORM_PHONE_NUMBER_ID=
WHATSAPP_PLATFORM_ACCESS_TOKEN=
WHATSAPP_PLATFORM_WABA_ID=
WHATSAPP_PLATFORM_DISPLAY_NAME=Tekrem AutoPilot
WHATSAPP_PLATFORM_DISPLAY_PHONE=+260...
# Set to true once PHONE_NUMBER_ID + ACCESS_TOKEN are filled in
WHATSAPP_PLATFORM_ENABLED=true

# WhatsApp Cloud API broadcasts (proactive messages require approved template)
WHATSAPP_BROADCAST_TEMPLATE=hello_world
WHATSAPP_USE_TEMPLATE_BROADCAST=true
WHATSAPP_SOCIAL_CALLBACK_URL=https://api.yourdomain.com/api/v1/social-accounts/oauth/whatsapp/callback

# AI
MISTRAL_API_KEY=CHANGE_ME
MISTRAL_TEXT_MODEL=mistral-small-latest
AI_USAGE_FREE_LIMIT=5000

# Storage (recommended for production media)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
SUPABASE_STORAGE_BUCKET=media

# Crons
AUTO_PUBLISH_CRON_ENABLED=true
DAILY_WORKFLOW_CRON_ENABLED=true
COMMENT_SYNC_CRON_ENABLED=true

# Payments
PAYMENTS_DEV_AUTO_COMPLETE=false
PAWAPAY_ENV=production

# Mail
MAIL_HOST=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com

