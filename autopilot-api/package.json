{
  "name": "custom-template-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "rimraf dist tsconfig.build.tsbuildinfo",
    "build": "nest build",
    "build:client": "cd ../autopilot-client && DISABLE_PWA=true VITE_API_BASE_URL= yarn build",
    "copy:client": "node scripts/copy-client-dist.js",
    "build:all": "yarn build:client && yarn copy:client && yarn build",
    "install:client": "cd ../autopilot-client && yarn install",
    "install:all": "yarn install && yarn install:client",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "gen:modules": "ts-node scripts/generate-modules.ts",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/main",
    "pm2:start": "mkdir -p logs /var/log/pm2 && npx pm2 start ecosystem.config.json --env production",
    "pm2:stop": "npx pm2 stop \"Mako API Production\"",
    "pm2:restart": "npx pm2 startOrRestart ecosystem.config.json --env production --update-env",
    "pm2:reload": "npx pm2 reload \"Mako API Production\" --env production --update-env",
    "pm2:delete": "npx pm2 delete \"Mako API Production\"",
    "pm2:logs": "npx pm2 logs \"Mako API Production\"",
    "pm2:status": "npx pm2 status \"Mako API Production\"",
    "pm2:save": "npx pm2 save",
    "pm2:startup": "npx pm2 startup",
    "deploy:prod": "bash scripts/deploy-production.sh --with-migrations",
    "deploy:pm2": "bash scripts/deploy-production.sh",
    "env:check": "node scripts/show-loaded-env.js",
    "db:test": "NODE_ENV=production node scripts/test-db-connection.js",
    "oauth:check": "NODE_ENV=production node scripts/check-oauth-env.js",
    "seed:dev": "ts-node -r ./scripts/polyfill-crypto.ts -r tsconfig-paths/register scripts/seed.ts",
    "seed:prod": "NODE_ENV=production ts-node -r ./scripts/polyfill-crypto.ts -r tsconfig-paths/register scripts/seed-production.ts",
    "migrations:run": "yarn migrations:run:dev",
    "migrations:run:dev": "NODE_ENV=development typeorm-ts-node-commonjs migration:run -d database/data-source.ts",
    "migrations:run:prod": "NODE_ENV=production typeorm-ts-node-commonjs migration:run -d database/data-source.ts",
    "migrations:revert": "yarn migrations:revert:dev",
    "migrations:revert:dev": "NODE_ENV=development typeorm-ts-node-commonjs migration:revert -d database/data-source.ts",
    "migrations:revert:prod": "NODE_ENV=production typeorm-ts-node-commonjs migration:revert -d database/data-source.ts",
    "migrations:show": "yarn migrations:show:dev",
    "migrations:show:dev": "NODE_ENV=development typeorm-ts-node-commonjs migration:show -d database/data-source.ts",
    "migrations:show:prod": "NODE_ENV=production typeorm-ts-node-commonjs migration:show -d database/data-source.ts",
    "storage:migrate": "ts-node -r ./scripts/polyfill-crypto.ts -r tsconfig-paths/register scripts/migrate-uploads-to-supabase.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@bull-board/api": "^7.2.1",
    "@bull-board/express": "^7.2.1",
    "@bull-board/nestjs": "^7.2.1",
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/extensions": "^4.4.0",
    "@gltf-transform/functions": "^4.4.0",
    "@mistralai/mistralai": "^2.2.5",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@supabase/supabase-js": "^2.108.1",
    "@types/lodash": "^4.14.191",
    "@types/passport-facebook": "^2.1.11",
    "@types/passport-google-oauth20": "^2.0.11",
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.2.0",
    "axios-retry": "^3.3.1",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.67.3",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "config": "^3.3.8",
    "connect-redis": "^9.0.0",
    "date-fns": "^2.29.3",
    "dotenv": "^16.4.7",
    "draco3dgltf": "^1.5.7",
    "ejs": "^3.1.8",
    "exceljs": "^4.4.0",
    "express-session": "^1.17.3",
    "googleapis": "^114.0.0",
    "helmet": "^6.0.0",
    "lodash": "^4.17.21",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.1",
    "nodemailer": "^6.9.1",
    "passport": "^0.6.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-oauth2": "^1.8.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.0",
    "pg": "^8.8.0",
    "ping": "^0.4.2",
    "redis": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "retry": "^0.13.1",
    "rimraf": "^3.0.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@types/bcrypt": "^6.0.0",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.13",
    "@types/jest": "^29",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.2.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-oauth2": "^1.8.0",
    "@types/supertest": "^2.0.11",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^29",
    "pm2": "^6.0.8",
    "prettier": "^2.8.8",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
