{
  "name": "custom-template-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "rimraf dist tsconfig.build.tsbuildinfo",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "gen:modules": "ts-node scripts/generate-modules.ts",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/main",
    "seed:dev": "ts-node -r ./scripts/polyfill-crypto.ts -r tsconfig-paths/register scripts/seed.ts",
    "migrations:run": "typeorm-ts-node-commonjs migration:run -d database/data-source.ts",
    "migrations:revert": "typeorm-ts-node-commonjs migration:revert -d database/data-source.ts",
    "migrations:show": "typeorm-ts-node-commonjs migration:show -d database/data-source.ts",
    "storage:migrate": "ts-node -r ./scripts/polyfill-crypto.ts -r tsconfig-paths/register scripts/migrate-uploads-to-supabase.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@mistralai/mistralai": "^2.2.5",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@supabase/supabase-js": "^2.108.1",
    "@types/lodash": "^4.14.191",
    "@types/passport-facebook": "^2.1.11",
    "@types/passport-google-oauth20": "^2.0.11",
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.2.0",
    "axios-retry": "^3.3.1",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.67.3",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "config": "^3.3.8",
    "date-fns": "^2.29.3",
    "ejs": "^3.1.8",
    "express-session": "^1.17.3",
    "googleapis": "^114.0.0",
    "helmet": "^6.0.0",
    "lodash": "^4.17.21",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.1",
    "nodemailer": "^6.9.1",
    "passport": "^0.6.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-oauth2": "^1.8.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.0",
    "pg": "^8.8.0",
    "ping": "^0.4.2",
    "reflect-metadata": "^0.2.2",
    "retry": "^0.13.1",
    "rimraf": "^3.0.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@types/bcrypt": "^6.0.0",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.13",
    "@types/jest": "^29",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.2.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-oauth2": "^1.8.0",
    "@types/supertest": "^2.0.11",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^29",
    "prettier": "^2.8.8",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
