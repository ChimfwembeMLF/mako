# Mako PRODUCTION .env — single app (Nest serves React + API)
# Server: /home/mako.tekreminnovations.com/public_html/autopilot-api/.env
# Copy to .env and fill CHANGE_ME from provider dashboards. Never commit real secrets.
# See docs/SINGLE_APP_DEPLOY.md

# =====================
# Server
# =====================
PORT=4005
NODE_ENV=production
APP_NAME=Tekrem Innovation Solutions - Mako

# Nest serves React build from client/dist (yarn deploy:prod)
SERVE_CLIENT=true
CORS_DISABLED=true

# One public domain — browser and API share this origin
FRONTEND_URL=https://mako.tekreminnovations.com
CLIENT_URL=https://mako.tekreminnovations.com
APP_URL=https://mako.tekreminnovations.com
API_PUBLIC_URL=https://mako.tekreminnovations.com
API_BASE_URL=https://mako.tekreminnovations.com
API_URL=https://mako.tekreminnovations.com

# =====================
# Database
# =====================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=mako
DB_PASSWORD=CHANGE_ME
DB_DATABASE=mako_prod
DB_NAME=mako_prod
DB_SYNCHRONIZE=false
DB_ENV=production
DB_SSL=false

CERTIFICATE_PATH=certs
CERTIFICATE_NAME=ca-certificate.crt

# =====================
# JWT
# =====================
JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# =====================
# Session & Security
# =====================
SESSION_SECRET=CHANGE_ME_LONG_RANDOM
SESSION_EXPIRY=86400
SESSION_SECURE=true
SESSION_SAME_SITE=lax

# CORS not needed when SERVE_CLIENT=true (same origin). Only if API-only mode:
# SERVE_CLIENT=false
# CORS_ORIGIN=https://mako.tekreminnovations.com
# CORS_CREDENTIALS=true

# =====================
# Legal / Meta app review
